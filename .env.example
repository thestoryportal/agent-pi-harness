# === Safe to inject into Claude Code context ===
# Variables with # INJECT are whitelisted in session_start.py

PROJECT_NAME=arhugula  # INJECT
OBSERVE_RETENTION_DAYS=7  # INJECT
LISTEN_PORT=8420  # INJECT
OBSERVE_PORT=8421  # INJECT
ENGINEER_NAME=  # INJECT — optional, used by notification.py TTS for personalized alerts

# === Secrets — NEVER injected into context ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_HOST=http://localhost:11434
LISTEN_API_KEY=
ELEVENLABS_API_KEY=  # optional — highest TTS priority in get_tts_script_path() (ElevenLabs > OpenAI > pyttsx3)

# === SP16: Voice & Real-Time prerequisites ===
# R01 TTS audio feedback (hooks-mastery) uses the keys above.
#   - ELEVENLABS_API_KEY > OPENAI_API_KEY > pyttsx3 (offline fallback)
#   - ENGINEER_NAME personalizes notification.py alerts (30% chance)
# R02 Voice-to-Claude (apps/voice/voice_to_claude_code.py) requires:
#   - OPENAI_API_KEY (used for TTS + text compression via gpt-4.1-mini)
#   - ANTHROPIC_API_KEY (used by the spawned `claude -p` subprocess)
#   - System prerequisite: `brew install portaudio` for sounddevice/RealtimeSTT
